# Local/sensitive data (not tracked in git)
.claude/local/

# Claude Code project settings (may contain permissions, hooks, allowed tools — machine-specific)
.claude/settings.json
.claude/settings.local.json

# Session logs may contain sensitive paths or system details
# Keep current session log tracked, archive older ones to local/ if sensitive
# .claude/session-log-*.md  # Uncomment if you want to exclude archived logs

# OS generated files
.DS_Store
Thumbs.db

# Conversation exports (large, raw session data — useful content is in session handoffs)
2026-*.txt

# Temporary files
*.tmp
*.bak

# Ephemeral logs and scratch data (downloads, benchmarks, test runs)
tmp/

# Benchmark results (large JSON + generated HTML, regenerated on each run)
benchmarks/results/

# Node.js dependencies (Puppeteer for HTML validation)
benchmarks/node_modules/

# Synced context files for portfolio chatbot (derived by sync-context.sh, uploaded to HF separately)
docs/portfolio/hf-space/context/*.md

# Python bytecode cache
__pycache__/

# Environment variables (API keys, secrets)
.env
# Aider working files (chat history, cache, tags — not config)
.aider.tags.cache.v0/
.aider.chat.history.md
.aider.input.history
.idea/.gitignore
.idea/llm.iml
.idea/misc.xml
.idea/modules.xml
.idea/vcs.xml
.idea/inspectionProfiles/profiles_settings.xml
